# reed solomon start


data_bytes = []
for i in range(0, len(byteurl), 8):
    data_bytes.append(int(byteurl[i:i+8], 2))

# 2. Galois Field Setup (GF(2^8))

exp = [1] * 512
log = [0] * 256
for i in range(1, 255):
    val = exp[i-1] << 1
    if val & 0x100: val ^= 0x11d # Polynomial x^8 + x^4 + x^3 + x^2 + 1
    exp[i] = val
    log[val] = i
for i in range(255, 512):
    exp[i] = exp[i - 255]

def gf_mul(x, y):
    if x == 0 or y == 0: return 0
    return exp[log[x] + log[y]]

# 3. Generator Polynomial for 10 ECC bytes (Version 2-L)
# These are the coefficients for: (x-a^0)(x-a^1)...(x-a^9)
generator = [1, 216, 194, 159, 111, 199, 94, 95, 113, 157, 193]

# 4. Polynomial Division (Reed-Solomon)
# We want to find the remainder after dividing data by the generator
ecc = [0] * 10
for byte in data_bytes:
    factor = byte ^ ecc[0]
    ecc = ecc[1:] + [0] # Shift
    if factor != 0:
        for i in range(10):
            ecc[i] ^= gf_mul(generator[i+1], factor)

# 5. Convert ECC bytes back to bitstring and append to byteurl
for byte in ecc:
    byteurl += format(byte, '08b')

# Update maxbits to include the 80 bits (10 bytes) of ECC
maxbits = 352 
