def placebytes():
    
    col = 24
    row = 24
    
   
    up = True
    right_side = True
    
    bit_index = 0
    
    
    while bit_index < len(byteurl):
        
        
        if col == 6:
            col -= 1
            
        
        if not app.reservedGrid[col][row]:
            bit = byteurl[bit_index]
            app.grid[col][row] = int(bit)
            
            bit_index += 1 
            
        
        if right_side:
           
            col -= 1
            right_side = False
        else:
            
            col += 1
            right_side = True
            
            if up:
                row -= 1
                if row < 0: 
                    row = 0
                    up = False
                    col -= 2 # 
                    right_side = True
            else:
                row += 1
                if row >= app.rows: 
                    row = app.rows - 1
                    up = True
                    col -= 2 
                    right_side = True
